  <diagram id="pipeline-python" name="Pipeline completo">
    <mxGraphModel dx="1810" dy="976" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p-title" value="Pipeline completo de id-sast-python" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="520" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="1. Entrada&#xa;&#xa;API o CLI construyen la solicitud&#xa;y delegan al servicio de escaneo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="2. Orquestacion de servicio&#xa;&#xa;ScanService valida la ruta, ajusta flags&#xa;y crea la instancia de PySAST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="240" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="3. Descubrimiento de archivos&#xa;&#xa;PySAST localiza archivos .py validos&#xa;y aplica limites de tamano/directorios" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="600" y="120" width="250" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="4. Parseo y normalizacion&#xa;&#xa;ASTParser genera el AST y ASTNormalizer&#xa;lo deja listo para las siguientes fases" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="890" y="120" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step5" value="5. Construccion de grafos&#xa;&#xa;CFGBuilder y DFGBuilder construyen&#xa;las estructuras de control y datos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1190" y="120" width="250" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step6a" value="6A. Hardcoded secrets&#xa;&#xa;HardcodedSecretAnalyzer detecta&#xa;credenciales expuestas en el codigo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="420" y="320" width="250" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step6b" value="6B. Taint analysis&#xa;&#xa;TaintAnalyzer recorre el DFG&#xa;y produce flujos potencialmente peligrosos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step7" value="7. Matching y analisis semantico&#xa;&#xa;PatternMatcher contrasta reglas integradas&#xa;y SemanticAnalyzer revisa flujos ambiguos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1030" y="320" width="290" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step8" value="8. Clasificacion&#xa;&#xa;VulnerabilityClassifier unifica findings,&#xa;asigna severidad, CWE y recomendacion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1370" y="320" width="280" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step9" value="9. Reglas IA opcionales&#xa;&#xa;RuleGenerator puede proponer reglas nuevas&#xa;a partir de hallazgos con flujo detectado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="720" y="500" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step10" value="10. Reporte canonico&#xa;&#xa;JSONReport consolida metadata, proyecto,&#xa;estadisticas, findings, IA y grafos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="500" width="290" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step11a" value="11A. Salida HTML&#xa;&#xa;HTMLReport genera el reporte visual&#xa;para revision manual" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1380" y="500" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step11b" value="11B. Salida consola&#xa;&#xa;ConsoleReport resume findings&#xa;cuando no se limita a HTML/JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1640" y="500" width="220" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step12" value="12. Contrato de servicio&#xa;&#xa;ScanService envuelve el resultado final,&#xa;agrega scan_id y resumen de severidad" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1030" y="700" width="290" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step13" value="13. Persistencia opcional&#xa;&#xa;ScanRepository guarda el documento final;&#xa;AnalysisRepository y RuleRepository guardan detalle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1370" y="700" width="310" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="step14" value="14. Respuesta final&#xa;&#xa;API devuelve ScanResponse y la CLI&#xa;imprime el mismo contrato en JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="720" y="700" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="gemini" value="Gemini support&#xa;&#xa;Se usa como apoyo semantico posterior&#xa;al analisis estatico, no como detector primario" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;dashed=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1030" y="900" width="420" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="pe1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step5" target="step6a">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1315" y="275"/>
              <mxPoint x="545" y="275"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="pe6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;" edge="1" parent="1" source="step5" target="step6b">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1315" y="275"/>
